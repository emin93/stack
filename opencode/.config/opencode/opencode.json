{
  "$schema": "https://opencode.ai/config.json",
  "model": "llama.cpp/local",
  "small_model": "llama.cpp/local",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "local": {
          "name": "Current llama-server model"
        }
      }
    }
  }
}
