{
  "$schema": "https://opencode.ai/config.json",
  "model": "dakodeon/local",
  "small_model": "dakodeon/local",
  "provider": {
    "dakodeon": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Dakodeon",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "timeout": 600000,
        "chunkTimeout": 60000
