{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "unsloth": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Unsloth Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8888/v1",
        "apiKey": "{env:UNSLOTH_STUDIO_API_KEY}"
      },
      "models": {
        "unsloth": {
          "name": "Unsloth Studio loaded model",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  }
}
