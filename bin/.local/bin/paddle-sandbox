#!/usr/bin/env bash
# Wrapper: spawn the Paddle MCP server pointed at the sandbox environment.
# Reads PADDLE_SANDBOX_API_KEY from the calling env (set it in ~/.zshrc.local).
set -euo pipefail
: "${PADDLE_SANDBOX_API_KEY:?PADDLE_SANDBOX_API_KEY not set — add it to ~/.zshrc.local}"
export PADDLE_API_KEY="$PADDLE_SANDBOX_API_KEY"
export PADDLE_ENVIRONMENT="sandbox"
exec paddle "$@"
