#!/usr/bin/env bash
# Launch Codex Desktop against the local oMLX server.
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:${HOME}/.local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

MODEL_REPO="Jackrong/Qwopus3.6-27B-v2-MLX-4bit"
MODEL_ID="Qwopus3.6-27B-v2-MLX-4bit"
MODEL_ROOT="${HOME}/.omlx/models"
MODEL_PATH="${MODEL_ROOT}/${MODEL_REPO}"
HOST="${OMLX_HOST:-127.0.0.1}"
PORT="${OMLX_PORT:-8000}"
BASE_URL="http://${HOST}:${PORT}/v1"
WORKSPACE="${1:-${CODEX_OMLX_WORKSPACE:-${HOME}/Documents/Projects}}"
LOG_DIR="${HOME}/Library/Logs/oMLX"
SERVER_LOG="${LOG_DIR}/server.log"
LAUNCHER_LOG="${LOG_DIR}/codex-omlx.log"
CODEX_CONFIG="${HOME}/.codex/config.toml"
CODEX_CONFIG_BACKUP="${LOG_DIR}/config.before-codex-omlx.toml"
LAUNCH_AGENT_LABEL="ch.emin.omlx-server"
LAUNCH_AGENT_PLIST="${HOME}/Library/LaunchAgents/${LAUNCH_AGENT_LABEL}.plist"

mkdir -p "$LOG_DIR"
exec >>"$LAUNCHER_LOG" 2>&1
printf '\n[%s] launcher start: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"

notify() {
  local title="$1"
  local message="$2"
  /usr/bin/osascript -e "display notification \"${message//\"/\\\"}\" with title \"${title//\"/\\\"}\"" >/dev/null 2>&1 || true
}

dialog() {
  local message="$1"
  /usr/bin/osascript -e "display dialog \"${message//\"/\\\"}\" buttons {\"OK\"} default button \"OK\" with title \"Codex oMLX\"" >/dev/null 2>&1 || true
}

require_command() {
  local command_name="$1"
  if ! command -v "$command_name" >/dev/null 2>&1; then
    dialog "Missing command: ${command_name}. Run the stack installer or brew bundle first."
    exit 127
  fi
}

server_has_model() {
  /usr/bin/curl -fsS --max-time 2 "${BASE_URL}/models" 2>/dev/null | /usr/bin/grep -Fq "\"${MODEL_ID}\""
}

codex_app_running() {
  [[ "$(/usr/bin/osascript -e 'application id "com.openai.codex" is running' 2>/dev/null || printf false)" == "true" ]]
}

quit_codex_if_running() {
  if ! codex_app_running; then
    return
  fi

  local response
  response=$(/usr/bin/osascript <<'APPLESCRIPT' 2>/dev/null || true
button returned of (display dialog "Codex is already running. To launch the oMLX version, Codex needs to quit and reopen with the local model settings." buttons {"Cancel", "Quit and Relaunch"} default button "Quit and Relaunch" cancel button "Cancel" with title "Codex oMLX")
APPLESCRIPT
)
  if [[ "$response" != "Quit and Relaunch" ]]; then
    exit 0
  fi

  /usr/bin/osascript -e 'tell application "Codex" to quit' >/dev/null 2>&1 || true
  local deadline=$((SECONDS + 20))
  while codex_app_running; do
    if (( SECONDS >= deadline )); then
      dialog "Codex did not quit cleanly. Quit it manually, then open Codex oMLX again."
      exit 1
    fi
    sleep 1
  done
}

activate_codex_omlx_config() {
  mkdir -p "$(dirname "$CODEX_CONFIG")" "$LOG_DIR"
  touch "$CODEX_CONFIG"
  cp "$CODEX_CONFIG" "$CODEX_CONFIG_BACKUP"

  CODEX_CONFIG="$CODEX_CONFIG" \
  OMLX_BASE_URL="$BASE_URL" \
  OMLX_MODEL_ID="$MODEL_ID" \
  python3 - <<'PY'
import os
import re
from pathlib import Path

path = Path(os.environ["CODEX_CONFIG"])
content = path.read_text()

def upsert_top_level(content, values):
    first_section = re.search(r"(?m)^\[", content)
    split_at = first_section.start() if first_section else len(content)
    head = content[:split_at]
    tail = content[split_at:]

    seen = set()
    lines = []
    for line in head.splitlines():
        match = re.match(r"^([A-Za-z0-9_-]+)\s*=", line)
        if match and match.group(1) in values:
            key = match.group(1)
            lines.append(f'{key} = "{values[key]}"')
            seen.add(key)
        else:
            lines.append(line)

    if lines == [""]:
        lines = []
    for key, value in values.items():
        if key not in seen:
            lines.append(f'{key} = "{value}"')

    new_head = "\n".join(lines).rstrip() + "\n\n"
    return new_head + tail.lstrip("\n")

def upsert_section(content, section, values):
    header = f"[{section}]"
    pattern = re.compile(rf"(?ms)^({re.escape(header)}\n)(.*?)(?=^\[|\Z)")
    match = pattern.search(content)
    if not match:
        block = "\n" + header + "\n" + "".join(f'{key} = "{value}"\n' for key, value in values.items())
        if content and not content.endswith("\n"):
            content += "\n"
        return content + block

    body = match.group(2)
    for key, value in values.items():
        line = f'{key} = "{value}"'
        if re.search(rf"(?m)^{re.escape(key)}\s*=", body):
            body = re.sub(rf"(?m)^{re.escape(key)}\s*=.*$", line, body)
        else:
            body += line + "\n"
    return content[:match.start(2)] + body + content[match.end(2):]

content = upsert_top_level(content, {
    "model_provider": "omlx",
    "model": os.environ["OMLX_MODEL_ID"],
    "model_reasoning_effort": "medium",
})
content = upsert_section(content, "model_providers.omlx", {
    "name": "oMLX",
    "base_url": os.environ["OMLX_BASE_URL"],
    "wire_api": "responses",
})
content = upsert_section(content, "profiles.omlx", {
    "model_provider": "omlx",
    "model": os.environ["OMLX_MODEL_ID"],
})
path.write_text(content)
PY
  printf '[%s] activated Codex oMLX config: %s via %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$MODEL_ID" "$BASE_URL"
}

restore_codex_config() {
  if [[ -f "$CODEX_CONFIG_BACKUP" ]]; then
    cp "$CODEX_CONFIG_BACKUP" "$CODEX_CONFIG"
    rm -f "$CODEX_CONFIG_BACKUP"
    printf '[%s] restored Codex config from backup\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  fi
}

recover_stale_session() {
  if [[ ! -f "$CODEX_CONFIG_BACKUP" ]]; then
    return
  fi

  if codex_app_running; then
    dialog "Codex oMLX is already running. Quit Codex before launching another oMLX session."
    exit 0
  fi

  printf '[%s] recovering stale Codex oMLX session\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  restore_codex_config
  stop_omlx_server
}

stop_omlx_server() {
  if /bin/launchctl print "gui/${UID}/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1; then
    /bin/launchctl bootout "gui/${UID}" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || \
      /bin/launchctl remove "$LAUNCH_AGENT_LABEL" >/dev/null 2>&1 || true
    printf '[%s] stopped oMLX LaunchAgent\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  fi
}

monitor_codex_lifetime() {
  printf '[%s] monitor waiting for Codex to appear\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  local deadline=$((SECONDS + 60))
  until codex_app_running; do
    if (( SECONDS >= deadline )); then
      printf '[%s] Codex did not appear; restoring config and stopping oMLX\n' "$(date '+%Y-%m-%d %H:%M:%S')"
      restore_codex_config
      stop_omlx_server
      return
    fi
    sleep 1
  done

  printf '[%s] monitor attached to Codex app lifetime\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  while codex_app_running; do
    sleep 2
  done

  printf '[%s] Codex closed; restoring config and stopping oMLX\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  restore_codex_config
  stop_omlx_server
  notify "Codex oMLX" "Codex closed; local oMLX server stopped."
}

start_omlx_if_needed() {
  if server_has_model; then
    return
  fi

  mkdir -p "$(dirname "$LAUNCH_AGENT_PLIST")"
  local omlx_bin
  omlx_bin="$(command -v omlx)"

  cat >"$LAUNCH_AGENT_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LAUNCH_AGENT_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${omlx_bin}</string>
    <string>serve</string>
    <string>--model-dir</string>
    <string>${MODEL_ROOT}</string>
    <string>--host</string>
    <string>${HOST}</string>
    <string>--port</string>
    <string>${PORT}</string>
  </array>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>${SERVER_LOG}</string>
  <key>StandardErrorPath</key>
  <string>${SERVER_LOG}</string>
</dict>
</plist>
EOF

  notify "Codex oMLX" "Starting local oMLX server..."
  /bin/launchctl print "gui/${UID}/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1 || \
    /bin/launchctl bootstrap "gui/${UID}" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  /bin/launchctl kickstart -k "gui/${UID}/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1 || true

  local deadline=$((SECONDS + 120))
  until server_has_model; do
    if ! /bin/launchctl print "gui/${UID}/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1; then
      dialog "oMLX did not start. Check ${SERVER_LOG}."
      exit 1
    fi
    if (( SECONDS >= deadline )); then
      dialog "Timed out waiting for oMLX at ${BASE_URL}. Check ${SERVER_LOG}."
      exit 1
    fi
    sleep 2
  done
}

main() {
  require_command omlx
  require_command codex
  require_command python3

  if [[ ! -f "${MODEL_PATH}/config.json" ]]; then
    dialog "Model not found at ${MODEL_PATH}. Download it with: hf download ${MODEL_REPO} --local-dir \"${MODEL_PATH}\""
    exit 1
  fi

  if [[ ! -d "$WORKSPACE" ]]; then
    WORKSPACE="$HOME"
  fi

  recover_stale_session
  quit_codex_if_running
  start_omlx_if_needed
  activate_codex_omlx_config

  notify "Codex oMLX" "Opening Codex with ${MODEL_ID}..."
  codex app "$WORKSPACE" >>"$LAUNCHER_LOG" 2>&1 &
  monitor_codex_lifetime &
}

main "$@"
