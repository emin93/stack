{
  "agent": {
    "commit_message_model": {
      "model": "gpt-5-mini",
      "provider": "copilot_chat",
    },
    "dock": "left",
    "play_sound_when_agent_done": "when_hidden",
    "sidebar_side": "left",
    "single_file_review": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
  },
  "auto_install_extensions": {
    "astro": true,
    "git-firefly": true,
    "kotlin": true,
    "macos-classic": true,
    "mdx": true,
    "swift": true,
    "toml": true,
    "vscode-icons": true,
    "xml": true,
  },
  "collaboration_panel": {
    "button": false,
  },
  "context_servers": {
    "browser-mcp": {
      "args": ["dlx", "@browsermcp/mcp@latest"],
      "command": "pnpm",
      "env": {},
    },
  },
  "debugger": {
    "button": false,
  },
  "diagnostics": {
    "button": false,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "file_types": {
    "JSON": ["xcstrings"],
    "XML": ["plist"],
  },
  "format_on_save": "on",
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "git_panel": {
    "dock": "right",
  },
  "icon_theme": {
    "dark": "VSCode Icons for Zed (Dark)",
    "light": "VSCode Icons for Zed (Light)",
    "mode": "system",
  },
  "outline_panel": {
    "button": false,
  },
  "project_panel": {
    "dock": "right",
  },
  "tabs": {
    "git_status": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "copy_on_select": true,
    "dock": "bottom",
    "font_family": "Menlo",
    "font_size": 13,
    "shell": "system",
  },
  "theme": {
    "dark": "macOS Classic Dark",
    "light": "macOS Classic Light",
    "mode": "system",
  },
}
