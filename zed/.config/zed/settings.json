{
  "auto_install_extensions": {
    "astro": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "kotlin": true,
    "mdx": true,
    "swift": true,
    "toml": true
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "agent_servers": {
    "Claude Code": {
      "type": "custom",
      "command": "claude",
      "args": ["--permission-mode", "bypassPermissions"],
      "env": {}
    },
    "Codex": {
      "type": "custom",
      "command": "codex-acp",
      "args": ["--yolo"],
      "env": {}
    }
  }
}
