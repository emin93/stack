{
  "agent_servers": {
    "Claude Code": {
      "args": ["dlx", "@agentclientprotocol/claude-agent-acp"],
      "command": "pnpm",
      "env": {},
      "type": "custom",
    },
    "Codex": {
      "args": [],
      "command": "codex-acp",
      "env": {},
      "type": "custom",
    },
  },
  "auto_install_extensions": {
    "astro": true,
    "kotlin": true,
    "macos-classic": true,
    "mdx": true,
    "swift": true,
    "toml": true,
    "vscode-icons": true,
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
  },
  "edit_predictions": {
    "provider": "none",
  },
  "file_types": {
    "JSON": ["xcstrings"],
  },
  "project_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "diagnostics": {
    "button": false,
  },
  "format_on_save": "on",
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "icon_theme": {
    "dark": "VSCode Icons for Zed (Dark)",
    "light": "VSCode Icons for Zed (Light)",
    "mode": "system",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "copy_on_select": true,
    "dock": "bottom",
    "font_family": "Menlo",
    "font_size": 13,
    "shell": "system",
  },
  "theme": {
    "dark": "macOS Classic Dark",
    "light": "macOS Classic Light",
    "mode": "system",
  },
}
