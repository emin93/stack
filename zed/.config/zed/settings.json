{
  "agent_servers": {
    "Claude Code": {
      "args": ["--permission-mode", "bypassPermissions"],
      "command": "claude",
      "env": {},
      "type": "custom"
    },
    "Codex": {
      "args": ["-c", "approval_policy=\"never\"", "-c", "sandbox_mode=\"danger-full-access\""],
      "command": "codex-acp",
      "env": {},
      "type": "custom"
    }
  },
  "auto_install_extensions": {
    "astro": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "kotlin": true,
    "mdx": true,
    "swift": true,
    "toml": true
  },
  "edit_predictions": {
    "provider": "none"
  },
  "format_on_save": "on",
  "git": {
    "inline_blame": {
      "enabled": true
    }
  },
  "icon_theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "system"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "copy_on_select": true,
    "dock": "bottom",
    "font_family": "Menlo",
    "font_size": 13,
    "shell": "system"
  },
  "theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "system"
  }
}
